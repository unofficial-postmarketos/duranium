---
# Generated image jobs for Duranium builds
# This file is generated by generate_image_jobs.py from image-jobs.yaml.j2

stages:
  - build-packages
  - build-image
  - deploy-image

{% for arch, combos in arch_combos.items() %}
build-packages-{{ arch }}:
  stage: build-packages
  image: alpine:edge
  tags:
    - {{ arch }}
  before_script:
    - apk add curl
    - "echo '140.211.167.182 gitlab.postmarketos.org' >> /etc/hosts"
    - curl -4fsSL "https://gitlab.postmarketos.org/postmarketOS/ci-common/-/raw/master/install_pmbootstrap.sh" | sh
    - su pmos -c "cd ~/.local/var/pmbootstrap/cache_git/pmaports && git checkout craftyguy/duranium-support"
  script:
    - su pmos -c "cd ~/.local/var/pmbootstrap/cache_git/pmaports && ./.ci/build-{{ arch }}.sh"
    - mkdir -p packages
    - find /home/pmos/.local/var/pmbootstrap/packages -name "*.apk" -exec cp {} packages/ \;
  artifacts:
    expire_in: 1 day
    paths:
      - packages/
  variables:
    ARCH: "{{ arch }}"

{% for combo in combos %}
build-image-{{ combo.device }}-{{ combo.ui }}-{{ combo.release }}:
  stage: build-image
  image: alpine:edge
  environment: build-image
  tags:
    - {{ arch }}
  needs: [build-packages-{{ arch }}]
  before_script:
    - apk upgrade -a
    # mkosi is in testing repo
    - echo "https://dl-cdn.alpinelinux.org/alpine/edge/testing" >> /etc/apk/repositories
    - |
      apk add bash \
              curl \
              distribution-gpg-keys \
              git \
              merge-usr \
              mkosi \
              python3
    - merge-usr

    # convert to pmOS
    - ln -sf /usr/share/distribution-gpg-keys/postmarketos/build.postmarketos.org.rsa.pub /etc/apk/keys
    - echo "http://mirror.postmarketos.org/postmarketos/extra-repos/systemd/master" >> /etc/apk/repositories
    - echo "http://mirror.postmarketos.org/postmarketos/master" >> /etc/apk/repositories
    - apk add postmarketos-base-systemd
    - apk add postmarketos-base

    # Generate image ID for this device+ui+release combo
    - export IMAGE_ID="${DEVICE}_${UI}_${RELEASE}"

    - |
      curl -fsSL -o mkosi.version \
      "https://duranium.postmarketos.org/images/${IMAGE_ID}/mkosi.version" 2>/dev/null || echo "" > mkosi.version

    # Install TEST keys for verity partition signing
    # FIXME: this is obviously not secure
    - cp "$MKOSI_KEY" mkosi.key
    - cp "$MKOSI_CRT" mkosi.crt
    - chmod 600 mkosi.key

  script:
    # Note: set workspace dir in /builds so that mkosi doesn't try to work
    # across multiple devices (e.g. / which is overlayfs)
    - |
      ./scripts/build-image.py device-$DEVICE ui-$UI \
        --release=$RELEASE \
        --package-directory packages \
        --workspace-directory=/builds/mkosi-workspace \
        --profile=compressed \
        --auto-bump
  artifacts:
    expire_in: 1 day
    paths:
      - mkosi.output/*/*.raw.zst
      - mkosi.output/*/*.efi
      - mkosi.output/*/SHA256SUMS
      - mkosi.version
  variables:
    DEVICE: "{{ combo.device }}"
    UI: "{{ combo.ui }}"
    RELEASE: "{{ combo.release }}"

deploy-image-{{ combo.device }}-{{ combo.ui }}-{{ combo.release }}:
  stage: deploy-image
  environment: deploy
  image: alpine:edge
  resource_group: manifest-{{ combo.device }}-{{ combo.ui }}-{{ combo.release }}
  needs:
    - build-image-{{ combo.device }}-{{ combo.ui }}-{{ combo.release }}
  before_script:
    - apk add openssh-client rsync
    - |
      mkdir -p "$HOME"/.ssh
      echo "$SSH_HOST_KEY" > "$HOME"/.ssh/known_hosts
      echo "$SSH_PRIVATE_KEY" > "$HOME"/.ssh/id_ed25519
      chmod 600 "$HOME"/.ssh/id_ed25519
  script:
    - export IMAGE_ID="${DEVICE}_${UI}_${RELEASE}"

    # Download existing manifest
    - scp -P "${SSH_PORT}" "${SSH_HOST}:/var/www/duranium.postmarketos.org/images/${IMAGE_ID}/SHA256SUMS" SHA256SUMS.old || touch SHA256SUMS.old

    # Merge manifests
    - mv mkosi.output/*/SHA256SUMS SHA256SUMS.new
    - cat SHA256SUMS.new SHA256SUMS.old > SHA256SUMS

    # Create remote directory
    - ssh -p "${SSH_PORT}" "${SSH_HOST}" "mkdir -p /var/www/duranium.postmarketos.org/images/${IMAGE_ID}"

    # Upload images
    - rsync -hrvz -e "ssh -p ${SSH_PORT}" mkosi.output/*/${IMAGE_ID}_*.* "${SSH_HOST}:/var/www/duranium.postmarketos.org/images/${IMAGE_ID}/"

    # Upload version and manifest
    - rsync -hrvz -e "ssh -p ${SSH_PORT}" mkosi.version SHA256SUMS "${SSH_HOST}:/var/www/duranium.postmarketos.org/images/${IMAGE_ID}/"
  variables:
    DEVICE: "{{ combo.device }}"
    UI: "{{ combo.ui }}"
    RELEASE: "{{ combo.release }}"

{% endfor %}
{% endfor %}
